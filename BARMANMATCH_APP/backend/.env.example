# BarmanMatch — variabili d'ambiente (COPIA in .env e compila; NON committare .env)

# ── Supabase (progetto dedicato BarmanMatch) ──────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=                      # service_role key (solo backend!)
SUPABASE_JWT_SECRET=               # JWT secret del progetto (verifica token HS256)

# ── CORS / URL pubblici ───────────────────────────────────────────
FRONTEND_ORIGIN=*                  # in prod: https://barmanmatch...,https://...
BMM_PUBLIC_URL=                    # base URL pubblica dell'app (per redirect Stripe)

# ── Entitlement / abbonamento STRUTTURE ───────────────────────────
# Lavoratori gratis; le venue hanno bisogno di entitlement attivo per
# pubblicare turni / assumere. Admin bypassa tutto.
BMM_ADMIN_EMAILS=                  # email admin separate da virgola (bypass + pannello admin)
BMM_ADMIN_UIDS=                    # (alternativa) uid Supabase admin, separati da virgola
BMM_TRIAL_DAYS=14                  # giorni di trial automatico alla creazione profilo venue (0 = solo sblocco admin)

# ── Commissioni / prelazione eventi ───────────────────────────────
PLATFORM_FEE_PCT=0.12              # commissione piattaforma sui contratti
EVENT_PRIORITY_HOURS=24            # durata finestra di prelazione eventi (BAD)

# ── Stripe (arrivera' dopo: abbonamento venue + escrow worker) ────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
